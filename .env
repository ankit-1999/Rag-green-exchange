# GreenGrid Exchange RAG AI — environment variables
# Copy this file to .env and fill in your values before running locally.
# On EC2, set these via SSM Parameter Store or instance user data.

# ── Application ───────────────────────────────────────────────
APP_NAME=GreenGrid Exchange RAG AI
APP_VERSION=1.0.0
DEBUG=false

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Amazon Bedrock ────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSION=1024
BEDROCK_LLM_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_LLM_MAX_TOKENS=1024
BEDROCK_LLM_TEMPERATURE=0.0

# ── Amazon OpenSearch Service ─────────────────────────────────
# Replace with your actual domain endpoint after infra is created
OPENSEARCH_ENDPOINT=https://vpc-greengrid-docs-poc-2ypemerq624jcuksdjbhlp7ami.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX_NAME=greengrid-docs
OPENSEARCH_TOP_K=5
# true = SigV4 auth (production/EC2)
# false = no auth (local docker)
OPENSEARCH_USE_AWS_AUTH=true

# ── Amazon S3 ─────────────────────────────────────────────────
S3_BUCKET_NAME=greengrid-documents-184434943294-poc

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# GreenGrid marketplace backend
MARKETPLACE_API_BASE_URL=https://greengridenergyexchange.onrender.com

# Marketplace HTTP settings
MARKETPLACE_API_CONNECT_TIMEOUT_SECONDS=10
MARKETPLACE_API_READ_TIMEOUT_SECONDS=45
MARKETPLACE_API_TIMEOUT_SECONDS=60
MARKETPLACE_API_PAGE_SIZE=100
MARKETPLACE_API_MAX_PAGES=100
MARKETPLACE_API_MAX_RETRIES=2
MARKETPLACE_API_VERIFY_SSL=true
MARKETPLACE_API_USER_AGENT=GreenGrid-RAG-AI/2.0

# Public read-only endpoints
MARKETPLACE_ALL_LISTINGS_PATH=/api/v1/public/listings
MARKETPLACE_ACTIVE_LISTINGS_PATH=/api/v1/listings/active
MARKETPLACE_ALL_PURCHASES_PATH=/api/v1/public/purchases

# Prediction and analytics
ANALYTICS_MIN_PURCHASE_RECORDS=30
ANALYTICS_MIN_HISTORY_PERIODS=6
ANALYTICS_DEFAULT_HISTORY_DAYS=180
ANALYTICS_RECENT_WINDOW_DAYS=7
ANALYTICS_SUPPORTING_WINDOW_DAYS=28
ANALYTICS_DEFAULT_WEEKLY_FORECAST_DAYS=7
ANALYTICS_LLM_SAMPLE_RECORDS=5
ANALYTICS_RECOMMENDATION_TIE_THRESHOLD=0.05