# GreenGrid Exchange RAG AI — environment variables
# Copy this file to .env and fill in your values before running locally.
# On EC2, set these via SSM Parameter Store or instance user data.

# ── Application ───────────────────────────────────────────────
APP_NAME=GreenGrid Exchange RAG AI
APP_VERSION=1.0.0
DEBUG=false

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Amazon Bedrock ────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSION=1024
BEDROCK_LLM_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_LLM_MAX_TOKENS=1024
BEDROCK_LLM_TEMPERATURE=0.0

# ── Amazon OpenSearch Service ─────────────────────────────────
# Replace with your actual domain endpoint after infra is created
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX_NAME=greengrid-docs
OPENSEARCH_TOP_K=5
# true = SigV4 auth (production/EC2)
# false = no auth (local docker)
OPENSEARCH_USE_AWS_AUTH=false

# ── Amazon S3 ─────────────────────────────────────────────────
S3_BUCKET_NAME=greengrid-documents

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
